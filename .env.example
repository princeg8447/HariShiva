# ─────────────────────────────────────────────────────────────
#  HariShiva V2 — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Weather ─────────────────────────────────────────

# OpenWeatherMap API key — https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key_here

# Fallback city when the user doesn't mention one
DEFAULT_CITY=Delhi

# ── Optional: Voice & Audio ───────────────────────────────────

# PulseAudio sink name for Bluetooth speaker output
# Find yours with: pactl list short sinks
AUDIO_SINK=bluez_sink.AA_BB_CC_DD_EE_FF.a2dp_sink

# Wake word that activates the assistant
# Options depend on your Porcupine keyword file
WAKE_WORD=hari

# Picovoice Porcupine Access Key for offline wake word detection
# Get a free AccessKey at https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# Path to a custom .ppn model file (optional, defaults to checking models/wake_word/)
WAKE_WORD_MODEL_PATH=

# Default language: 'en' (English) or 'hi' (Hindi)
DEFAULT_LANG=en

# ── Optional: Vision ──────────────────────────────────────────

# OpenCV camera index (0 = first camera, 1 = second, etc.)
CAMERA_INDEX=0

# Set to 'false' to disable the camera/vision subsystem entirely
ENABLE_VISION=true

# ── Optional: Voice subsystem ─────────────────────────────────

# Set to 'false' to disable STT/TTS (text-only mode)
ENABLE_VOICE=true

# ── Optional: Face Recognition ────────────────────────────────

# Lower value = stricter matching (range: 0.3 – 0.6)
RECOGNITION_TOLERANCE=0.42

# ── Optional: Object Detection ────────────────────────────────

# Path or model name for YOLO weights
# yolov8n.pt is downloaded automatically on first run
YOLO_MODEL_PATH=yolov8n.pt
